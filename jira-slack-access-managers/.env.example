# Local development environment variables
# Copy to .env and fill in values
# NOTE: In production (GCP VM), secrets come from Secret Manager instead

GCP_PROJECT_ID=your-gcp-project-id
GCS_BUCKET_NAME=your-gcp-project-id-compliance-reviews
JIRA_SITE_URL=https://acme.atlassian.net

# Local dev fallbacks (only used if Secret Manager is not available)
# These map to Secret Manager key names with dashes replaced by underscores
JIRA_ACCESS_REVIEW_TOKEN=your-jira-api-token
JIRA_ADMIN_EMAIL=reviewer@acme.example.com
SLACK_ACCESS_REVIEW_BOT_TOKEN=xoxb-your-slack-bot-token
